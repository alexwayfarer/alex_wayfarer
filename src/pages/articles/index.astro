---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const href = (p) => `${base.replace(/\/$/, '')}${p}`;

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Articles" description="Writing from Alex Wayfarer.">
  <h1>Articles</h1>
  <p class="lede">Notes from the road.</p>

  {articles.length === 0 ? (
    <p>No articles yet — check back soon.</p>
  ) : (
    <ul class="article-list">
      {articles.map((a) => (
        <li>
          <a class="title" href={href(`/articles/${a.id}/`)}>{a.data.title}</a>
          <p class="meta">{fmt(a.data.pubDate)}</p>
          <p class="desc">{a.data.description}</p>
          <p>{a.data.tags.map((t) => <span class="tag">{t}</span>)}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
